# !!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!
# --- SMTP Configuration for Grafana ---
# Must be filled to enable email notifications (Monitoring Alerts)
# Look at docs/setup/installation.md for more details
GF_SMTP_USER=<email-example@gmail.com>
GF_SMTP_PASSWORD=<password-example>
GF_SMTP_FROM_ADDRESS=<email-example@gmail.com>
# !!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!

# --- Kafka Configuration ---
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_TOPIC=crypto_trades
SCHEMA_REGISTRY_URL=http://schema-registry:8081
SCHEMA_PATH=/opt/airflow/config/schemas/crypto_trades.avsc
# Docker Compose Variables
KAFKA_HOST=kafka
KAFKA_PORT=9092
KAFKA_EXTERNAL_PORT=29092
ZOOKEEPER_HOST=zookeeper
ZOOKEEPER_PORT=2181
SCHEMA_REGISTRY_HOST=schema-registry
SCHEMA_REGISTRY_PORT=8085

# --- Postgres Configuration ---
POSTGRES_URL=jdbc:postgresql://postgres:5432/airflow
POSTGRES_USER=airflow
POSTGRES_PASSWORD=airflow
POSTGRES_DRIVER=org.postgresql.Driver
# Docker Compose Variables
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_EXTERNAL_PORT=5433 # Added external port mapping (Avoid Conflict with local Postgres)
POSTGRES_DB=airflow

# --- S3 / MinIO Configuration ---
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin123
S3_BUCKET_NAME=crypto-data
# Docker Compose Variables
MINIO_HOST=minio
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# --- Grafana Configuration ---
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# Docker Compose Variables
GRAFANA_PORT=3000
PROMETHEUS_PORT=9090

# --- Spark Configuration ---
# Docker Compose Variables
SPARK_MASTER_HOST=spark-master
SPARK_MASTER_PORT=7077
SPARK_MASTER_WEB_PORT=8090
SPARK_WORKER_WEB_PORT=8091

# --- Airflow Core  ---
AIRFLOW_UID=50000
# AIRFLOW__CORE__EXECUTOR=LocalExecutor
# AIRFLOW__CORE__SQL_ALCHEMY_CONN=postgresql+psycopg2://airflow:airflow@postgres/airflow

# Docker Compose Variables
AIRFLOW_PROJ_DIR=.
AIRFLOW_WWW_USER_USERNAME=airflow
AIRFLOW_WWW_USER_PASSWORD=airflow
AIRFLOW_API_SERVER_PORT=8080